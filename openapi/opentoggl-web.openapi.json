          "state": {
            "type": "string"
          },
          "enterprise": {
            "type": "boolean",
            "nullable": true
          }
        },
        "required": ["plan_name", "state"]
      },
      "UpdateCurrentUserProfileRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "fullname": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "beginning_of_week": {
            "type": "integer"
          },
          "country_id": {
            "type": "integer"
          },
          "default_workspace_id": {
            "type": "integer"
          },
          "current_password": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
