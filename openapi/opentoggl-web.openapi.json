      "UpdateWorkspaceSettingsRequest": {
        "$ref": "./toggl-track-api-v9.swagger.json#/definitions/workspace.Payload"
      },
      "UserPreferences": {
        "$ref": "./toggl-track-api-v9.swagger.json#/definitions/models.AllPreferences"
