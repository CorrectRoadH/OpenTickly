          "organization": {
            "$ref": "#/components/schemas/OrganizationSettings"
          },
          "subscription": {
            "$ref": "#/components/schemas/SubscriptionView",
            "nullable": true
          }
        },
        "required": ["organization"]
      },
      "OrganizationSettingsUpdate": {
        "type": "object",
        "properties": {
          "organization": {
            "$ref": "#/components/schemas/UpdateOrganizationSettingsRequest"
          }
        },
        "required": ["organization"]
      },
      "QuotaWindow": {
        "$ref": "./opentoggl-shared.openapi.json#/components/schemas/QuotaWindow"
      },
      "ProjectCreateRequest": {
        "type": "object",
        "properties": {
          "workspace_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "billable": {
            "type": "boolean"
          },
          "color": {
            "type": "string",
            "nullable": true
          }
        },
        "required": ["workspace_id", "name"]
      },
      "ProjectListEnvelope": {
        "type": "object",
        "properties": {
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectView"
            }
          }
        },
        "required": ["projects"]
      },
      "ProjectMember": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "integer"
          },
          "member_id": {
            "type": "integer"
          },
          "role": {
            "type": "string",
            "nullable": true
          }
        },
        "required": ["project_id", "member_id"]
      },
      "ProjectMemberGrantRequest": {
        "type": "object",
        "properties": {
          "member_id": {
            "type": "integer"
          },
          "role": {
            "type": "string",
            "nullable": true
          }
        },
        "required": ["member_id"]
      },
      "ProjectMembersEnvelope": {
        "type": "object",
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectMember"
            }
          }
        },
        "required": ["members"]
      },
      "ProjectUpdateRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "billable": {
            "type": "boolean"
          },
          "archived": {
            "type": "boolean"
          },
          "color": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ProjectView": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "workspace_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "billable": {
            "type": "boolean"
          },
          "archived": {
            "type": "boolean"
          },
          "color": {
            "type": "string",
            "nullable": true
          }
        },
        "required": ["id", "workspace_id", "name", "archived"]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          },
          "fullname": {
            "type": "string"
          }
        },
        "required": ["email", "password"]
      },
