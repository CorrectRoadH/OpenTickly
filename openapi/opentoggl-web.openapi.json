      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": ["email", "password"]
      },
      "OrganizationSettings": {
        "$ref": "./toggl-track-api-v9.swagger.json#/definitions/models.MeOrganization"
      },
      "OrganizationSettingsEnvelope": {
        "type": "object",
