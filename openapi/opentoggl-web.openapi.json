        "properties": {
          "current_organization_id": {
            "type": "integer",
            "nullable": true
          },
          "current_workspace_id": {
            "type": "integer",
            "nullable": true
          },
          "organization_subscription": {
            "$ref": "#/components/schemas/SubscriptionView",
            "nullable": true
          },
          "organizations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganizationSettings"
            }
          },
          "user": {
            "$ref": "#/components/schemas/CurrentUserProfile"
          },
          "workspace_capabilities": {
            "$ref": "#/components/schemas/CapabilitySnapshot",
            "nullable": true
          },
          "workspace_quota": {
            "$ref": "#/components/schemas/QuotaWindow",
            "nullable": true
          },
          "workspace_subscription": {
            "$ref": "#/components/schemas/SubscriptionView",
            "nullable": true
          },
          "workspaces": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkspaceSettings"
            }
          }
        },
        "required": [
          "user",
          "organizations",
          "workspaces",
          "workspace_capabilities",
          "workspace_quota"
        ]
      },
      "SubscriptionView": {
        "$ref": "./toggl-track-api-v9.swagger.json#/definitions/subscription.OutData"
      },
      "UpdateCurrentUserProfileRequest": {
        "$ref": "./toggl-track-api-v9.swagger.json#/definitions/me.payload"
      },
      "UpdateOrganizationSettingsRequest": {
        "$ref": "./toggl-track-api-v9.swagger.json#/definitions/models.PutPayload"
