{
  "name": "opentoggl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run build -r",
    "check": "vp check && vp run check -r",
    "test": "vp run test -r",
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "self-hosted:verify": "node tools/self-hosted/cli.mjs verify",
    "self-hosted:smoke": "node tools/self-hosted/cli.mjs smoke",
    "self-hosted:up": "node tools/self-hosted/cli.mjs up",
    "dev:website": "vp run website#dev",
    "dev:backend": "go run ./apps/backend",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@vitejs/plugin-react": "^5.1.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1"
}
