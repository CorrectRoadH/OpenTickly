# Copy to `.env.self-hosted` before running docker compose for self-hosted packaging,
# deployment rehearsal, and release smoke verification.
#
# This file is for self-hosted/release workflows only.
# Source-based local development must continue to use root `.env.local`.

# Release image reference used by docker compose.
# For local rehearsal with --build, keeping this as `opentoggl:local` is fine.
OPENTOGGL_IMAGE=opentoggl:local

# Public HTTP port on the host.
OPENTOGGL_PORT=8080

# PostgreSQL container settings.
OPENTOGGL_POSTGRES_DB=opentoggl
OPENTOGGL_POSTGRES_USER=postgres
OPENTOGGL_POSTGRES_PASSWORD=postgres

# Optional host port mapping for operator schema tooling.
OPENTOGGL_POSTGRES_PORT=5432

# Runtime datasource values consumed by the OpenToggl process.
OPENTOGGL_DATABASE_URL=postgres://postgres:postgres@postgres:5432/opentoggl?sslmode=disable
OPENTOGGL_REDIS_URL=redis://redis:6379/0

# pgschema operator values for schema plan/apply against the same PostgreSQL.
# These values must target the same database as OPENTOGGL_DATABASE_URL.
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=opentoggl
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=disable

# Optional runtime tuning.
OPENTOGGL_FILESTORE_NAMESPACE=opentoggl
OPENTOGGL_JOBS_QUEUE_NAME=default
