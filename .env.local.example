# Copy to `.env.local` and override values for your machine when needed.
#
# The frontend (`vp run website#dev`) and backend (`air`)
# both read local-development settings from the repository root.
# `.env.local` is required for the default source-based backend startup path.
# Run `air` from the repository root so this file is discovered.
# `air` must fail immediately if this file or the required datasource env is
# missing, and it must connect to the real PostgreSQL and Redis dependencies
# you started separately.

OPENTOGGL_WEB_PROXY_TARGET=http://127.0.0.1:8080
OPENTOGGL_SERVICE_NAME=opentoggl-api
PORT=8080
DATABASE_URL=postgres://opentoggl@localhost/opentoggl
REDIS_URL=redis://127.0.0.1:6379/0
OPENTOGGL_FILESTORE_NAMESPACE=opentoggl
OPENTOGGL_JOBS_QUEUE_NAME=default
