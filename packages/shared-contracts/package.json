{
  "name": "@opentoggl/shared-contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "generate": "node ./scripts/generate-shared-contracts.mjs && node ./scripts/generate-shared-contracts.mjs --source ../../openapi/opentoggl-web.openapi.json --target ./src/generated/web-contracts.generated.ts && vp check --fix src/generated/public-contracts.generated.ts src/generated/web-contracts.generated.ts",
    "test": "vp test run",
    "check": "vp check"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
