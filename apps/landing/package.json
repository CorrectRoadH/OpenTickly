{
  "name": "@opentickly/landing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "node scripts/optimize-images.mjs && react-router typegen && fumadocs-mdx && react-router build",
    "postbuild": "cp ./serve.json ./build/client/serve.json && rm -rf ./dist && mkdir -p ./dist && cp -R ./build/client/. ./dist/ && cp ./serve.json ./dist/serve.json && find ./build/client ./dist -path '*/index.html' -type f -print0 | xargs -0 perl -0pi -e 's/<link rel=\"modulepreload\"[^>]*>//g'",
    "preview": "serve -c serve.json ./build/client",
    "check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "test": "vp test run",
    "start": "serve -c serve.json ./build/client",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@opentickly/web-ui": "workspace:*",
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^8.2.0",
    "fumadocs-core": "16.11.1",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "16.11.1",
    "isbot": "^5.2.0",
    "lucide-react": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@orama/tokenizers": "^3.1.18",
    "@react-router/dev": "^7.17.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.1",
    "serve": "^14.2.6",
    "sharp": "catalog:",
    "tailwindcss": "^4.3.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
