{
  "name": "@opentoggl/landing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router typegen && fumadocs-mdx && react-router build",
    "postbuild": "cp ./serve.json ./build/client/serve.json && rm -rf ./dist && mkdir -p ./dist && cp -R ./build/client/. ./dist/ && cp ./serve.json ./dist/serve.json",
    "preview": "serve -c serve.json ./build/client",
    "check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "start": "serve -c serve.json ./build/client",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^7.13.1",
    "fumadocs-core": "16.7.5",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.5",
    "isbot": "^5.1.36",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@orama/tokenizers": "^3.1.18",
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.0",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vite": "^8.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
